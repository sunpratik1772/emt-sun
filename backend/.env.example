# Copy to backend/.env and fill in values.
#
#   cp backend/.env.example backend/.env

# --- Gemini (API key mode — default) ---
# Required for Sherpa workflow generation and agent nodes (ENV1 — tried first):
GEMINI_API_KEY=
# Failover keys — adapter rotates on timeout, rate limit, or resource exhausted:
# GEMINI_API_KEY_2=
# GEMINI_API_KEY_3=
# Legacy alias (optional fallback):
# GOOGLE_API_KEY=

# --- Vertex AI (optional — see docs/gemini-migration.md) ---
# LLM_PROVIDER=vertex
# VERTEX_PROJECT=
# VERTEX_LOCATION=us-central1

# --- Harness / generation ---
# Parallel planning subagents — LLM bullets in the activity timeline (on by default when GEMINI_API_KEY is set)
# HARNESS_PARALLEL_LLM_SUBAGENTS=1
# HARNESS_PARALLEL_LLM_MAX_OUTPUT_TOKENS=280
# Set to 0 to disable runtime smoke during generation (faster drafts)
# DBSHERPA_RUNTIME_SMOKE=0

# --- Optional integrations (see docs/mcp-integrations.md) ---
# GITHUB_TOKEN=
# ATLASSIAN_EMAIL=
# ATLASSIAN_API_TOKEN=
# TEAMS_INCOMING_WEBHOOK_URL=
# SOLR_URL=
# ORACLE_DSN=
